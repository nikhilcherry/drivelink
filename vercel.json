{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "drivelink.tech" }],
      "destination": "https://www.drivelink.tech/:path*",
      "permanent": true
    }
  ]
}
