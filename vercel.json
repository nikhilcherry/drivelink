{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/docs",
      "missing": [{ "type": "host", "value": "core.drivelink.tech" }],
      "destination": "https://core.drivelink.tech/docs",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "drivelink.tech" }],
      "destination": "https://www.drivelink.tech/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!_next/|.*\\.(?:png|svg|ico|xml|txt|jpg|jpeg|webp|json)$).*)",
      "has": [{ "type": "host", "value": "core.drivelink.tech" }],
      "destination": "/docs"
    }
  ]
}
